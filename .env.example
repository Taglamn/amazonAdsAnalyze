# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=4096
GEMINI_CONTINUATION_ROUNDS=2

# Lingxing ERP credentials (manual configuration required)
LINGXING_ERP_USERNAME=
LINGXING_ERP_PASSWORD=

# Lingxing OpenAPI credentials
LINGXING_APP_ID=
LINGXING_APP_SECRET=
LINGXING_BASE_URL=https://openapi.lingxing.com
LINGXING_TIMEOUT_SECONDS=90
LINGXING_MAX_RETRIES=3
LINGXING_RETRY_BACKOFF_SECONDS=1.5
LINGXING_TLS_MODE=default
LINGXING_PROXY_URL=
LINGXING_INSECURE_SKIP_VERIFY=false

# Context package async export
CONTEXT_EXPORT_MAX_WORKERS=1
CONTEXT_EXPORT_RETENTION_HOURS=24

# Lingxing sync async jobs
LINGXING_SYNC_MAX_WORKERS=1
LINGXING_SYNC_RETENTION_HOURS=72

# Customer Service AI module
CUSTOMER_SERVICE_DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/amazon_ads
CUSTOMER_SERVICE_REDIS_URL=redis://redis:6379/0
CUSTOMER_SERVICE_LLM_PROVIDER=gemini
CUSTOMER_SERVICE_LLM_MODEL=gemini-2.5-flash
CUSTOMER_SERVICE_MAX_REPLY_CHARS=1200
CUSTOMER_SERVICE_LINGXING_LIST_MESSAGES_PATH=/erp/sc/message/lists
CUSTOMER_SERVICE_LINGXING_LIST_MESSAGES_METHOD=POST
CUSTOMER_SERVICE_LINGXING_LIST_MESSAGES_STORE_NAME_FIELD=seller_name
CUSTOMER_SERVICE_LINGXING_LIST_MESSAGES_SID_FIELD=sid
CUSTOMER_SERVICE_LINGXING_SEND_MESSAGE_PATH=/erp/sc/message/reply
CUSTOMER_SERVICE_LINGXING_SEND_MESSAGE_METHOD=POST
CUSTOMER_SERVICE_LINGXING_SEND_MESSAGE_STORE_NAME_FIELD=seller_name
CUSTOMER_SERVICE_LINGXING_SEND_MESSAGE_SID_FIELD=sid
CUSTOMER_SERVICE_LINGXING_SEND_MESSAGE_CONVERSATION_FIELD=conversation_id
CUSTOMER_SERVICE_LINGXING_SEND_MESSAGE_REPLY_FIELD=reply
OPENAI_API_KEY=

# Auth / RBAC / Multi-tenant
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/amazon_ads
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120
JWT_REFRESH_EXPIRE_DAYS=30
BCRYPT_ROUNDS=12
BOOTSTRAP_TENANT_NAME=default
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=ChangeThisPassword123!
