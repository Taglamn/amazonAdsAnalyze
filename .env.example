# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=4096
GEMINI_CONTINUATION_ROUNDS=2

# Lingxing ERP credentials (manual configuration required)
LINGXING_ERP_USERNAME=
LINGXING_ERP_PASSWORD=

# Lingxing OpenAPI credentials
LINGXING_APP_ID=
LINGXING_APP_SECRET=
LINGXING_BASE_URL=https://openapi.lingxing.com
LINGXING_TIMEOUT_SECONDS=90
LINGXING_MAX_RETRIES=3
LINGXING_RETRY_BACKOFF_SECONDS=1.5
LINGXING_TLS_MODE=default
LINGXING_PROXY_URL=
LINGXING_INSECURE_SKIP_VERIFY=false
